# Token de API de IONOS Cloud
IONOS_TOKEN=your_token_here

# ID del datacenter (encuéntralo en la consola de IONOS Cloud o via API)
IONOS_DATACENTER_ID=your_datacenter_id_here

# Lista de nombres de VM separados por comas (tal como aparecen en la consola de IONOS Cloud)
# Ejemplo: VM_NAMES=mi-servidor-web,mi-servidor-bd
VM_NAMES=vm-name-1,vm-name-2
